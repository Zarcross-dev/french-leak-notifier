# URL du webhook Discord (obligatoire)
WEBHOOK_URL=https://discord.com/api/webhooks/VOTRE_ID/VOTRE_TOKEN

# Mode de notification : realtime | 1d | 7d | 30d (défaut : realtime)
NOTIFICATION_MODE=realtime

# Intervalle de vérification en secondes - mode realtime uniquement (défaut : 300)
CHECK_INTERVAL=300
